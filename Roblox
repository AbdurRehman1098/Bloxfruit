--  📡  WEBHOOK  (auto-detects executor HTTP function)
-- ══════════════════════════════════════════════════════════════
local HttpService = game:GetService("HttpService")

local function getRequestFn()
    for _, name in ipairs({ "request", "http_request", "syn_request" }) do
        local fn = getgenv and getgenv()[name]
        if type(fn) == "function" then return fn end
    end
    if type(request)      == "function" then return request      end
    if type(http_request) == "function" then return http_request end
    if type(syn_request)  == "function" then return syn_request  end
    return nil
end

local function sendWebhook(fruitName, position, sniped)
    local fn = getRequestFn()
    if not fn then return end

    local rarity = FRUIT_RARITY[fruitName] or "Common"
    local emoji  = FRUIT_EMOJI[rarity] or "⚪"
    local color  = RARITY_COLOR[rarity] or RARITY_COLOR.Common

    local ok, serverId = pcall(function() return game.JobId end)
    serverId = (ok and serverId and #serverId > 0) and serverId or "N/A"

    local status = sniped and "✅ `Sniped & Stored`" or "⚠️ `Detected (not sniped)`"

    local desc = table.concat({
        emoji .. " **" .. fruitName .. "** — `" .. rarity .. "`",
        "",
        "📍 **Position** `X:" .. math.floor(position.X) .. "  Y:" .. math.floor(position.Y) .. "  Z:" .. math.floor(position.Z) .. "`",
        "🎯 **Action** " .. status,
        "",
        "🌐 **Server ID**",
        "```" .. serverId .. "```",
    }, "\n")

    local payload = HttpService:JSONEncode({
        username   = "🍈 BF Sniper",
        avatar_url = "https://static.wikia.nocookie.net/blox-piece/images/thumb/5/5f/Flame_Fruit.png/120px-Flame_Fruit.png",
        embeds = {{
            title       = emoji .. " Fruit Sniped!",
            description = desc,
            color       = color,
            footer      = { text = "BF Sniper + Webhook" },
            timestamp   = os.date("!%Y-%m-%dT%H:%M:%SZ"),
        }},
    })

    pcall(fn, {
        Url     = WEBHOOK_URL,
        Method  = "POST",
        Headers = { ["Content-Type"] = "application/json" },
        Body    = payload,
    })
end

