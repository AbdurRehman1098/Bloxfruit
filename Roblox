--  🛒 DEALER SHOP — Mirage-style stock embed
-- ══════════════════════════════════════════════════════════════

-- Stock change happens every ~4 hours in Blox Fruits
-- We track when we first saw the current stock to estimate refresh time
local dealerStockSeen  = nil   -- os.time() when current stock was first detected
local dealerLastStock  = {}    -- set of fruit names in last detected stock

local function stockChangeText()
    if not dealerStockSeen then return "Unknown" end
    local elapsed = os.time() - dealerStockSeen
    local h = math.floor(elapsed / 3600)
    local m = math.floor((elapsed % 3600) / 60)
    if h > 0 then
        return string.format("%dh %dm ago", h, m)
    else
        return string.format("%dm ago", m)
    end
end

local function buildDealerEmbed(stockList)
    -- stockList = array of { name, price }
    -- Sort by price ascending
    table.sort(stockList, function(a, b) return a[2] < b[2] end)

    local lines = {}
    for _, item in ipairs(stockList) do
        local name  = item[1]
        local price = item[2]
        local data  = FRUIT_DATA[name] or {}
        local emoji = data[2] or "🍑"
        table.insert(lines, string.format("%s **%s** • 💰`%s`", emoji, name, commify(price)))
    end

    local stockText   = table.concat(lines, "\n")
    local changeText  = stockChangeText()
    local servId      = getServerId()

    return {
        title       = "🏪 Current Blox Fruit Dealer Stock",
        description = stockText .. "\n\n" ..
                      "⏰ **Stock changed:** `" .. changeText .. "`\n" ..
                      "🌐 **Server:** `" .. servId .. "`",
        color       = 0x5865F2,
        footer      = { text = "BF Notifier • Dealer Shop • " .. getPlayer() },
        timestamp   = timestamp(),
    }
end

--[[
    Real Blox Fruit Dealer detection:
    The game stores the active dealer stock in the GUI that opens when
    you approach the NPC. We scan:
    1. The NPC model's descendant TextLabels for "FruitName - Price" format
    2. PlayerGui for any open dealer shop frames
    3. The actual RemoteFunction call is server-side so we rely on GUI
--]]
local function readDealerStock()
    local found = {}  -- { [fruitName] = price }

    -- ① PlayerGui scan — the most reliable source when GUI is open
    local lp = Players.LocalPlayer
    if lp then
        local playerGui = lp:FindFirstChild("PlayerGui")
        if playerGui then
            for _, desc in ipairs(playerGui:GetDescendants()) do
                if desc:IsA("TextLabel") and desc.Visible then
                    local txt = desc.Text or ""
                    -- Match "FruitName" anywhere in the label
                    for fruitName, data in pairs(FRUIT_DATA) do
                        if txt == fruitName or txt:find("^" .. fruitName .. "$") then
                            -- Price is often in a sibling or parent label
                            local parent = desc.Parent
                            if parent then
                                for _, sib in ipairs(parent:GetChildren()) do
                                    if sib:IsA("TextLabel") and sib ~= desc then
                                        local numStr = sib.Text:gsub(",", ""):gsub("[^%d]", "")
                                        local price = tonumber(numStr)
                                        if price and price >= 1000 then
                                            found[fruitName] = price
                                        end
                                    end
                                end
                            end
                            -- Also try attribute price
                            local attrPrice = desc:GetAttribute("Price") or desc.Parent and desc.Parent:GetAttribute("Price")
                            if attrPrice then found[fruitName] = tonumber(attrPrice) or data[1] end
                        end
                        -- Pattern: "Dragon 3,500,000" or "Dragon\n3,500,000"
                        local matchedPrice = txt:match("^" .. fruitName .. "[%s\n%-]+([%d,]+)")
                        if matchedPrice then
                            found[fruitName] = tonumber(matchedPrice:gsub(",", "")) or data[1]
                        end
                    end

                    -- Generic "Name - Price" pattern on a single label
                    local rawFruit, rawPrice = txt:match("^([%a]+)%s*[%-%:]%s*([%d,]+)")
                    if rawFruit and rawPrice and FRUIT_DATA[rawFruit] then
                        found[rawFruit] = tonumber(rawPrice:gsub(",", "")) or FRUIT_DATA[rawFruit][1]
                    end
                end
            end
        end
    end

    -- ② Workspace NPC scan — fallback
    local dealerNPCs = {
        "Blox Fruit Dealer", "Blox Fruits Dealer",
        "Mysterious Scientist", "Fruit Dealer",
    }
    for _, npcName in ipairs(dealerNPCs) do
        local npc = Workspace:FindFirstChild(npcName, true)
        if npc then
            for _, desc in ipairs(npc:GetDescendants()) do
                if desc:IsA("TextLabel") then
                    local txt = desc.Text or ""
                    local rawFruit, rawPrice = txt:match("^([%a]+)%s*[%-%:]%s*([%d,]+)")
                    if rawFruit and rawPrice and FRUIT_DATA[rawFruit] then
                        found[rawFruit] = tonumber(rawPrice:gsub(",", "")) or FRUIT_DATA[rawFruit][1]
                    end
                    -- Name-only label
                    if FRUIT_DATA[txt] then
                        if not found[txt] then found[txt] = FRUIT_DATA[txt][1] end
                    end
                end
            end
        end
    end

    return found
end

local function fruitSetHash(stock)
    local keys = {}
    for k in pairs(stock) do table.insert(keys, k) end
    table.sort(keys)
    return table.concat(keys, "|")
end

local function scanDealerShop()
    local stock = readDealerStock()
    if next(stock) == nil then return end  -- nothing found, GUI probably not open

    -- Detect stock change
    local newHash = fruitSetHash(stock)
    local oldHash = fruitSetHash(dealerLastStock)

    if newHash ~= oldHash then
        -- Stock changed (or first detection)
        dealerStockSeen = os.time()
        dealerLastStock = stock
    end

    -- Check if any watched fruit is in current stock
    local watchedInStock = {}
    for fruitName, price in pairs(stock) do
        if watchSet[fruitName] then
            table.insert(watchedInStock, { fruitName, price })
        end
    end

    if #watchedInStock == 0 then return end

    -- Build full stock list for the embed (show everything that's in stock)
    local allStock = {}
    for fruitName, price in pairs(stock) do
        table.insert(allStock, { fruitName, price })
    end

    -- Rate-limit: only send if stock changed OR cooldown passed
    local now = os.time()
    if lastDealerSent and (now - lastDealerSent) < CONFIG.NOTIFY_COOLDOWN then return end
    lastDealerSent = now

    -- Build watched fruit names for the ping text
    local watchedNames = {}
    for _, item in ipairs(watchedInStock) do
        table.insert(watchedNames, item[1])
    end

    local content = CONFIG.DEALER_PING .. " 🛒 **" .. table.concat(watchedNames, ", ") .. "** is in the Dealer right now!"

    print("[BF Notifier] 🛒 Dealer stock contains watched fruit(s): " .. table.concat(watchedNames, ", "))
    sendWebhook(CONFIG.DEALER_WEBHOOK, {
        content    = content,
        username   = "🛒 BF Dealer Alert",
        avatar_url = "https://static.wikia.nocookie.net/blox-piece/images/thumb/5/5f/Flame_Fruit.png/120px-Flame_Fruit.png",
        embeds     = { buildDealerEmbed(allStock) },
    })
end

