-- ══════════════════════════════════════════════════════════════
--  📡  HTTP (Xeno / KRNL / Fluxus / Synapse auto-detect)
-- ══════════════════════════════════════════════════════════════
local function getRequestFn()
    for _, name in ipairs({ "request", "http_request", "syn_request" }) do
        local fn = getgenv and getgenv()[name]
        if type(fn) == "function" then return fn end
    end
    if type(request)      == "function" then return request      end
    if type(http_request) == "function" then return http_request end
    if type(syn_request)  == "function" then return syn_request  end
    return nil
end

local function sendWebhook(url, payload)
    local fn = getRequestFn()
    if not fn then
        warn("[BF Notifier] No HTTP function found. Your executor may not support 'request'.")
        return
    end
    pcall(fn, {
        Url     = url,
        Method  = "POST",
        Headers = { ["Content-Type"] = "application/json" },
        Body    = HttpService:JSONEncode(payload),
    })
end

