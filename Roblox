local function buildSpawnEmbed(fruitName, pos)
    local rarity = getRarity(fruitName)
    return {
        title       = "🍑 Fruit Spawned in World!",
        description = string.format("A **%s** fruit has been detected on the map!", fruitName),
        color       = getRarityColor(rarity),
        fields      = {
            { name = "🍈 Fruit",       value = fruitName,                                              inline = true  },
            { name = "⭐ Rarity",      value = rarity,                                                 inline = true  },
            { name = "📍 Position",    value = string.format("X:%.0f | Y:%.0f | Z:%.0f", pos.X, pos.Y, pos.Z), inline = false },
            { name = "🌐 Server ID",   value = getServerId(),                                          inline = true  },
            { name = "👤 Detected By", value = getPlayer(),                                            inline = true  },
        },
        footer    = { text = "BF Notifier • World Spawn" },
        timestamp = getTimestamp(),
    }
end

local function getPosition(obj)
    if obj:IsA("Model") and obj.PrimaryPart then
        return obj.PrimaryPart.Position
    elseif obj:IsA("BasePart") then
        return obj.Position
    elseif obj:IsA("Model") then
        for _, child in ipairs(obj:GetChildren()) do
            if child:IsA("BasePart") then return child.Position end
        end
    end
    return Vector3.new(0, 0, 0)
end

local function parseFruitName(obj)
    local name = obj.Name

    -- Check StringValue / attribute "FruitName" on Models
    if obj:IsA("Model") then
        local sv = obj:FindFirstChild("FruitName") or obj:FindFirstChild("Fruit")
        if sv and sv:IsA("StringValue") and #sv.Value > 0 then return sv.Value end
        local attr = obj:GetAttribute("FruitName") or obj:GetAttribute("Fruit")
        if attr then return tostring(attr) end
    end

    -- Pattern: "DragonFruit", "Dragon_Fruit"
    local a = name:match("^(.-)_?[Ff]ruit$")
    if a and #a > 0 then return a end

    -- Pattern: "Fruit_Dragon", "FruitDragon"
    local b = name:match("^[Ff]ruit[_]?(.+)$")
    if b and #b > 0 then return b end

    -- Direct rarity table match
    if FRUIT_RARITY[name] then return name end

    return nil
end

local function scanWorldFruits()
    local roots = { Workspace }
    for _, folder in ipairs({ "Fruits", "Map", "Items", "Drops", "FruitStorage" }) do
        local f = Workspace:FindFirstChild(folder)
        if f then table.insert(roots, f) end
    end

    for _, root in ipairs(roots) do
        for _, obj in ipairs(root:GetDescendants()) do
            if obj:IsA("Model") or obj:IsA("BasePart") then
                local fruitName = parseFruitName(obj)
                if fruitName then
                    local id  = tostring(obj)
                    local now = os.time()
                    if not notifiedFruits[id] or (now - notifiedFruits[id]) > CONFIG.NOTIFY_COOLDOWN then
                        notifiedFruits[id] = now
                        local pos = getPosition(obj)
                        print("[BF Notifier] 🍑 Found: " .. fruitName)
                        sendWebhook(CONFIG.FRUIT_SPAWN_WEBHOOK, buildSpawnEmbed(fruitName, pos))
                    end
                end
            end
        end
    end

    -- Clean old entries (> 10 min)
    local now = os.time()
    for id, ts in pairs(notifiedFruits) do
        if now - ts > 600 then notifiedFruits[id] = nil end
    end
end

