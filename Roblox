--  🛠️  HELPERS
-- ══════════════════════════════════════════════════════════════
local function getServerId()
    local ok, id = pcall(function() return game.JobId end)
    return (ok and id and #id > 0) and id or "N/A"
end

local function getLocalPlayer()
    local lp = Players.LocalPlayer
    return lp and (lp.DisplayName .. " (`" .. lp.Name .. "`)") or "Unknown"
end

local function timestamp()
    return os.date("!%Y-%m-%dT%H:%M:%SZ")
end

-- ══════════════════════════════════════════════════════════════
--  🍑  FRUIT DETECTION  (matches Blox Fruits sniper logic)
-- ══════════════════════════════════════════════════════════════

-- Returns true if the instance is a dropped Blox Fruit Tool
local function isFruit(obj)
    return obj:IsA("Tool")
        and obj:FindFirstChild("Handle") ~= nil
        and string.find(obj.Name, "Fruit") ~= nil
end

-- Returns all fruits currently dropped in Workspace root
local function getAllFruits()
    local fruits = {}
    for _, v in ipairs(Workspace:GetChildren()) do
        if isFruit(v) then
            table.insert(fruits, v)
        end
    end
    return fruits
end

-- ══════════════════════════════════════════════════════════════
--  💬  EMBED BUILDER — clean, bold, backtick style
-- ══════════════════════════════════════════════════════════════
local function buildEmbed(fruit)
    local name   = fruit.Name
    local data   = FRUIT_DATA[name]
    local emoji  = data and data[1] or "🍑"
    local rarity = data and data[2] or "Unknown"
    local color  = RARITY_COLOR[rarity] or RARITY_COLOR.Unknown

    local pos = fruit.Handle and fruit.Handle.Position or Vector3.new(0, 0, 0)
    local serverId = getServerId()

    local desc = table.concat({
        emoji .. " **" .. name .. "** — `" .. rarity .. "`",
        "",
        "📍 **Position** `X:" .. math.floor(pos.X) .. "  Y:" .. math.floor(pos.Y) .. "  Z:" .. math.floor(pos.Z) .. "`",
        "👤 **Detected by** " .. getLocalPlayer(),
        "",
        "🌐 **Server ID**",
        "```" .. serverId .. "```",
    }, "\n")

    return {
        title       = emoji .. " Fruit Dropped!",
        description = desc,
        color       = color,
        footer      = { text = "BF Notifier • Fruit Spawn" },
        timestamp   = timestamp(),
    }
end

-- ══════════════════════════════════════════════════════════════
--  🔁  MAIN SCAN LOOP
-- ══════════════════════════════════════════════════════════════
local scanTimer = 0

print("╔══════════════════════════════════════════════╗")
print("║   🍈 Blox Fruits Spawn Notifier v4  ACTIVE   ║")
print("╚══════════════════════════════════════════════╝")
print("[BF Notifier] Server: " .. getServerId())
print("[BF Notifier] Player: " .. (Players.LocalPlayer and Players.LocalPlayer.Name or "?"))

RunService.Heartbeat:Connect(function(dt)
    scanTimer = scanTimer + dt
    if scanTimer < CONFIG.SCAN_INTERVAL then return end
    scanTimer = 0

    local ok, err = pcall(function()
        local now    = os.time()
        local fruits = getAllFruits()

        for _, fruit in ipairs(fruits) do
            local id = tostring(fruit)

            if not notified[id] or (now - notified[id]) > CONFIG.NOTIFY_COOLDOWN then
                notified[id] = now
                print("[BF Notifier] 🍑 Detected: " .. fruit.Name)

                sendWebhook(CONFIG.FRUIT_SPAWN_WEBHOOK, {
                    username   = "🍈 BF Fruit Notifier",
                    avatar_url = "https://static.wikia.nocookie.net/blox-piece/images/thumb/5/5f/Flame_Fruit.png/120px-Flame_Fruit.png",
                    embeds     = { buildEmbed(fruit) },
                })
            end
        end

        -- Cleanup stale entries (> 10 min)
        for id, ts in pairs(notified) do
            if now - ts > 600 then notified[id] = nil end
        end
    end)

    if not ok then
        warn("[BF Notifier] Scan error: " .. tostring(err))
    end
end)

print("[BF Notifier] ✅ Monitoring started!")
