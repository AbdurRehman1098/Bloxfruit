-- ── Helpers ───────────────────────────────────────────────────
local function getRarity(name)
    return FRUIT_RARITY[name] or "Unknown"
end

local function getRarityColor(rarity)
    return RARITY_COLORS[rarity] or RARITY_COLORS.Unknown
end

local function getTimestamp()
    return os.date("!%Y-%m-%dT%H:%M:%SZ")
end

local function getServerId()
    local ok, id = pcall(function() return game.JobId end)
    return (ok and id and #id > 0) and (id:sub(1,8).."...") or "Unknown"
end

local function getPlayer()
    local lp = Players.LocalPlayer
    return lp and (lp.DisplayName.." (@"..lp.Name..")") or "Unknown"
end

-- ── HTTP sender (supports Xeno, KRNL, Fluxus, Synapse) ───────
local function httpPost(url, body)
    -- Try different request APIs available in various executors
    local apis = { "request", "http_request", "syn_request" }
    local fn = nil

    for _, name in ipairs(apis) do
        if type(getgenv()[name]) == "function" then
            fn = getgenv()[name]
            break
        end
    end

    -- Fallback: check globals directly
    if not fn then
        fn = request or http_request or syn_request
    end

    if not fn then
        warn("[BF Notifier] No HTTP function found! Make sure your executor supports 'request'.")
        return
    end

    local ok, err = pcall(fn, {
        Url     = url,
        Method  = "POST",
        Headers = { ["Content-Type"] = "application/json" },
        Body    = body,
    })

    if not ok then
        warn("[BF Notifier] Webhook error: " .. tostring(err))
    end
end

local function sendWebhook(url, embed)
    local payload = HttpService:JSONEncode({
        username   = "🍈 BF Notifier",
        avatar_url = "https://static.wikia.nocookie.net/blox-piece/images/thumb/5/5f/Flame_Fruit.png/120px-Flame_Fruit.png",
        embeds     = { embed },
    })
    httpPost(url, payload)
end

