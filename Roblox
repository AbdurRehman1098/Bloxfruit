--  🌍 WORLD FRUIT SPAWN — Clean embed with full server ID
-- ══════════════════════════════════════════════════════════════
local function buildSpawnEmbed(fruitName, pos)
    local data    = FRUIT_DATA[fruitName] or {}
    local emoji   = data[2] or "🍑"
    local rarity  = data[3] or "Unknown"
    local price   = data[1] and (commify(data[1]) .. " Beli") or "Unknown"
    local color   = RARITY_COLOR[rarity] or 0xF4A460
    local servId  = getServerId()
    local link    = getDirectLink()

    local desc = string.format(
        "%s **%s** `(%s)` just dropped on the map!\n\n" ..
        "💰 **Price:** `%s`\n" ..
        "📍 **Position:** `X:%.0f  Y:%.0f  Z:%.0f`",
        emoji, fruitName, rarity, price, pos.X, pos.Y, pos.Z
    )

    local fields = {
        { name = "🌐 Full Server ID", value = "```" .. servId .. "```", inline = false },
        { name = "👤 Detected By",    value = getPlayer(),               inline = true  },
    }

    if link then
        table.insert(fields, { name = "🔗 Join Link", value = "[Click to join](" .. link .. ")", inline = true })
    end

    return {
        title       = "🍑 Fruit Spotted in the World!",
        description = desc,
        color       = color,
        fields      = fields,
        footer      = { text = "BF Notifier • World Spawn" },
        timestamp   = timestamp(),
    }
end

local function getPosition(obj)
    if obj:IsA("Model") then
        if obj.PrimaryPart then return obj.PrimaryPart.Position end
        for _, c in ipairs(obj:GetChildren()) do
            if c:IsA("BasePart") then return c.Position end
        end
    elseif obj:IsA("BasePart") then
        return obj.Position
    end
    return Vector3.new(0, 0, 0)
end

local function parseFruitName(obj)
    local name = obj.Name

    -- StringValue / Attribute
    if obj:IsA("Model") then
        for _, key in ipairs({ "FruitName", "Fruit", "Name" }) do
            local sv = obj:FindFirstChild(key)
            if sv and sv:IsA("StringValue") and FRUIT_DATA[sv.Value] then return sv.Value end
            local attr = obj:GetAttribute(key)
            if attr and FRUIT_DATA[tostring(attr)] then return tostring(attr) end
        end
    end

    -- "DragonFruit" / "Dragon_Fruit"
    local a = name:match("^(.-)_?[Ff]ruit$")
    if a and FRUIT_DATA[a] then return a end

    -- "Fruit_Dragon" / "FruitDragon"
    local b = name:match("^[Ff]ruit[_]?(.+)$")
    if b and FRUIT_DATA[b] then return b end

    -- Direct match
    if FRUIT_DATA[name] then return name end

    return nil
end

local function scanWorldFruits()
    local roots = { Workspace }
    for _, folder in ipairs({ "Fruits", "Map", "Items", "Drops", "FruitStorage", "Dropped" }) do
        local f = Workspace:FindFirstChild(folder)
        if f then table.insert(roots, f) end
    end

    local now = os.time()
    for _, root in ipairs(roots) do
        for _, obj in ipairs(root:GetDescendants()) do
            if obj:IsA("Model") or obj:IsA("BasePart") then
                local fruitName = parseFruitName(obj)
                if fruitName then
                    local id = tostring(obj)
                    if not notifiedSpawns[id] or (now - notifiedSpawns[id]) > CONFIG.NOTIFY_COOLDOWN then
                        notifiedSpawns[id] = now
                        local pos = getPosition(obj)
                        print("[BF Notifier] 🍑 Fruit dropped: " .. fruitName)
                        sendWebhook(CONFIG.FRUIT_SPAWN_WEBHOOK, {
                            username   = "🍈 BF Fruit Spawn",
                            avatar_url = "https://static.wikia.nocookie.net/blox-piece/images/thumb/5/5f/Flame_Fruit.png/120px-Flame_Fruit.png",
                            embeds     = { buildSpawnEmbed(fruitName, pos) },
                        })
                    end
                end
            end
        end
    end

    -- Cleanup stale entries
    for id, ts in pairs(notifiedSpawns) do
        if now - ts > 600 then notifiedSpawns[id] = nil end
    end
end

