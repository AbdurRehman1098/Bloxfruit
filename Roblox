            { name = "🌐 Server ID", value = getServerId(),                inline = true  },
            { name = "👤 Player",    value = getPlayer(),                  inline = true  },
            { name = "⚡ Action",    value = "**Join now and buy it!**",   inline = false },
        },
        footer    = { text = "BF Notifier • Dealer Shop" },
        timestamp = getTimestamp(),
    }
end

local function scanDealerShop()
    local currentStock = {}

    -- ① Search NPC models by name
    local dealerNPCNames = {
        "Blox Fruit Dealer", "Blox Fruits Dealer",
        "Mysterious Scientist", "Gacha Remover", "Fruit Dealer",
    }

    for _, npcName in ipairs(dealerNPCNames) do
        local npc = Workspace:FindFirstChild(npcName, true)
        if npc then
            -- Check sub-folders for stock data
            for _, folder in ipairs({ "Stock", "Fruits", "Inventory" }) do
                local sf = npc:FindFirstChild(folder)
                if sf then
                    for _, item in ipairs(sf:GetChildren()) do
                        local fname = item:IsA("StringValue") and item.Value or item.Name
                        local price = item:GetAttribute("Price") or "?"
                        currentStock[fname] = tostring(price)
                    end
                end
            end

            -- Check TextLabels inside NPC GUIs
            for _, gui in ipairs(npc:GetDescendants()) do
                if gui:IsA("TextLabel") then
                    -- e.g. "Dragon - 2,500,000"
                    local fruit, price = gui.Text:match("^([%a]+)%s*%-+%s*([%d,]+)")
                    if fruit and FRUIT_RARITY[fruit] then
                        currentStock[fruit] = price
                    end
                    -- Also plain fruit name match
                    for fname in pairs(FRUIT_RARITY) do
                        if gui.Text:find(fname) then
                            currentStock[fname] = gui.Text:match("([%d,]+)") or "?"
                        end
                    end
                end
            end
        end
    end

    -- ② Scan PlayerGui for any open Dealer GUIs
    local lp = Players.LocalPlayer
    if lp then
        local pGui = lp:FindFirstChild("PlayerGui")
        if pGui then
            for _, desc in ipairs(pGui:GetDescendants()) do
                if desc:IsA("TextLabel") and desc.Text then
                    local txt = desc.Text
                    for fname in pairs(FRUIT_RARITY) do
                        if txt:find(fname) then
                            currentStock[fname] = txt:match("([%d,]+)") or "?"
                        end
                    end
                end
            end
        end
    end

    -- ③ Notify for any watched fruit found in stock
    local now = os.time()
    for fname, price in pairs(currentStock) do
        if dealerWatchSet[fname] then
            local key = "dealer_" .. fname
            if not lastDealerFruits[key] or (now - lastDealerFruits[key]) > CONFIG.NOTIFY_COOLDOWN then
                lastDealerFruits[key] = now
                print("[BF Notifier] 🛒 Dealer has watched fruit: " .. fname)
                sendWebhook(CONFIG.DEALER_WEBHOOK, buildDealerEmbed(fname, price))
            end
        end
    end
end

