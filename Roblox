--  🔁  MAIN  (original logic + webhook call injected)
-- ══════════════════════════════════════════════════════════════
local function Main()
    Status.Text = 'Status: <font color="rgb(255,255,0)" weight="Regular">Searching fruit...</font>'

    local fruits = GetAllFruits()

    if #fruits == 0 then
        Status.Text = 'Status: <font color="rgb(255,0,0)" weight="Regular">No fruit found, server hopping...</font>'
        task.wait(2)
        ServerHop()
        return
    end

    for _, fruit in pairs(fruits) do
        CreateESP(fruit)
    end

    local target = GetBestFruit(fruits)

    Status.Text = 'Status: <font color="rgb(0,255,0)" weight="Regular">Fruit found</font>'
    FruitType.Text = 'Fruit Type: <font color="rgb(0,255,0)" weight="Regular">' .. target.Name .. "</font>"

    -- 📡 Send webhook BEFORE tweening (so you know even if it gets picked up)
    local fruitPos = target.Handle.Position
    sendWebhook(target.Name, fruitPos, false)   -- detected

    TweenTo(fruitPos)
    task.wait(1)

    local stored = StoreFruit(target)

    if stored then
        -- 📡 Send second webhook confirming it was stored
        StoreStatus.Text = 'Storing Status: <font color="rgb(0,255,0)" weight="Regular">Fruit Stored</font>'
        sendWebhook(target.Name, fruitPos, true)   -- sniped & stored
    end

    task.wait(2)
    ServerHop()
end

Main()
