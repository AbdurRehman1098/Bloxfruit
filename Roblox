-- ── Format number with commas ─────────────────────────────────
local function commify(n)
    local s = tostring(math.floor(n))
    return s:reverse():gsub("(%d%d%d)", "%1,"):reverse():gsub("^,", "")
end

-- ── Get full server Job ID ────────────────────────────────────
local function getServerId()
    local ok, id = pcall(function() return game.JobId end)
    return (ok and id and #id > 0) and id or "N/A"
end

-- ── Get place ID (for direct server link) ────────────────────
local function getDirectLink()
    local ok, placeId = pcall(function() return game.PlaceId end)
    local ok2, jobId  = pcall(function() return game.JobId end)
    if ok and ok2 then
        return "roblox://experiences/start?placeId=" .. tostring(placeId) .. "&gameInstanceId=" .. tostring(jobId)
    end
    return nil
end

-- ── Local player ─────────────────────────────────────────────
local function getPlayer()
    local lp = Players.LocalPlayer
    return lp and (lp.DisplayName .. " (@" .. lp.Name .. ")") or "Unknown"
end

-- ── Timestamp ─────────────────────────────────────────────────
local function timestamp()
    return os.date("!%Y-%m-%dT%H:%M:%SZ")
end

